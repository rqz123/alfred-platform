# Alfred Platform - Environment Configuration
# Copy to .env and fill in your values

# Shared
OPENAI_API_KEY=sk-your-key-here
SECRET_KEY=change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Inter-service API keys
OURCENTS_API_KEY=change-me-ourcents-key
THREAD_API_KEY=change-me-thread-key
NUDGE_API_KEY=change-me-nudge-key    # kept for backward compat; use THREAD_API_KEY going forward
ALFRED_INTERNAL_KEY=change-me-internal-key

# Gateway - port 8000
APP_NAME=Alfred
ENVIRONMENT=production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
DATABASE_URL=sqlite:////data/alfred.db
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGIN_ALT=http://127.0.0.1:5173
DISPATCH_ENABLED=true

# Intent detection
INTENT_OPENAI_API_KEY=${OPENAI_API_KEY}
INTENT_OPENAI_MODEL=gpt-4o-mini

# WhatsApp (leave Cloud API fields blank to use Bridge/whatsapp-web.js mode)
WHATSAPP_API_VERSION=v21.0
WHATSAPP_MODE=bridge
WHATSAPP_VERIFY_TOKEN=change-me-verify-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=

# STT / TTS
STT_PROVIDER=openai
STT_OPENAI_MODEL=whisper-1
TTS_PROVIDER=disabled
TTS_OPENAI_MODEL=tts-1
TTS_OPENAI_VOICE=alloy
TTS_AUDIO_FORMAT=mp3

# Bridge - port 3001
BRIDGE_API_KEY=change-me-bridge-key
BACKEND_BASE_URL=http://localhost:8000/api
PORT=3001
PUPPETEER_HEADLESS=true
WELCOME_MESSAGE_ENABLED=true
WELCOME_MESSAGE_TEXT=I am online and ready to help you.

# OurCents - port 8001
OURCENTS_DATABASE_PATH=/data/ourcents.db
OURCENTS_RECEIPTS_STORAGE_PATH=/data/receipts
OURCENTS_TEMP_UPLOAD_PATH=/data/temp
OURCENTS_AI_PROVIDER=openai
OURCENTS_OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
OURCENTS_MAX_UPLOAD_SIZE_MB=10
OURCENTS_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg,image/webp

# Brain - port 8003
BRAIN_API_KEY=change-me-brain-key
BRAIN_URL=http://localhost:8003
# QDRANT_URL options (no Docker needed for local dev):
#   local:///data/qdrant   → persistent local file (recommended for dev)
#   :memory:               → in-memory (ephemeral, resets on restart)
#   http://localhost:6333  → remote/Docker Qdrant server
QDRANT_URL=local:///data/qdrant
BRAIN_PORT=8003

# Thread - port 8002
THREAD_URL=http://localhost:8002/api/thread
THREAD_DATABASE_URL=sqlite:////data/thread.db
THREAD_DEFAULT_TIMEZONE=America/Los_Angeles
THREAD_PORT=8002
GATEWAY_URL=http://localhost:8000
