# =============================================================
# Alfred Platform — Unified Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================

# ─────────────────────────────────────────────
# Shared — used by multiple services
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
SECRET_KEY=change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ─────────────────────────────────────────────
# Inter-service API keys
# Each downstream service validates X-Alfred-API-Key against ALFRED_API_KEY.
# docker-compose maps OURCENTS_API_KEY → ALFRED_API_KEY inside the ourcents
# container, and NUDGE_API_KEY → ALFRED_API_KEY inside the nudge container.
# ─────────────────────────────────────────────
OURCENTS_API_KEY=change-me-ourcents-key
NUDGE_API_KEY=change-me-nudge-key
ALFRED_INTERNAL_KEY=change-me-internal-key

# ─────────────────────────────────────────────
# Gateway (WhatsApp backend) — port 8000
# ─────────────────────────────────────────────
APP_NAME=Alfred
ENVIRONMENT=production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
DATABASE_URL=sqlite:////data/alfred.db
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGIN_ALT=http://127.0.0.1:5173

# Dispatch
DISPATCH_ENABLED=true

# Intent detection (LLM-first, keyword fallback if unset)
INTENT_OPENAI_API_KEY=${OPENAI_API_KEY}
INTENT_OPENAI_MODEL=gpt-4o-mini

# WhatsApp Cloud API (leave blank to use Bridge/whatsapp-web.js mode)
WHATSAPP_API_VERSION=v21.0
WHATSAPP_MODE=bridge
WHATSAPP_VERIFY_TOKEN=change-me-verify-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=

# STT / TTS
STT_PROVIDER=openai
STT_OPENAI_MODEL=whisper-1
TTS_PROVIDER=disabled
TTS_OPENAI_MODEL=tts-1
TTS_OPENAI_VOICE=alloy
TTS_AUDIO_FORMAT=mp3

# ─────────────────────────────────────────────
# Bridge (Node.js WhatsApp Web adapter) — port 3001
# In Docker, BACKEND_BASE_URL is overridden to http://gateway:8000/api
# ─────────────────────────────────────────────
BRIDGE_API_KEY=change-me-bridge-key
BACKEND_BASE_URL=http://localhost:8000/api
PORT=3001
PUPPETEER_HEADLESS=true
WELCOME_MESSAGE_ENABLED=true
WELCOME_MESSAGE_TEXT=I am online and ready to help you.

# ─────────────────────────────────────────────
# OurCents (expense tracker) — port 8001
# In Docker, ALFRED_API_KEY is set to OURCENTS_API_KEY by docker-compose.
# ─────────────────────────────────────────────
OURCENTS_DATABASE_PATH=/data/ourcents.db
OURCENTS_RECEIPTS_STORAGE_PATH=/data/receipts
OURCENTS_TEMP_UPLOAD_PATH=/data/temp
OURCENTS_AI_PROVIDER=openai
OURCENTS_OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
OURCENTS_MAX_UPLOAD_SIZE_MB=10
OURCENTS_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg,image/webp

# ─────────────────────────────────────────────
# Nudge (reminder service) — port 8002
# In Docker, ALFRED_API_KEY is set to NUDGE_API_KEY by docker-compose.
# In Docker, GATEWAY_URL is overridden to http://gateway:8000.
# ─────────────────────────────────────────────
NUDGE_DATABASE_URL=sqlite:////data/nudge.db
NUDGE_FIRE_INTERVAL_SECONDS=60
GATEWAY_URL=http://localhost:8000
